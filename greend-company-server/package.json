{
  "name": "@greend/greend-company-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Central GreenD server for enterprise deployment. Hosts the UI and API while persisting data on the company server filesystem.",
  "main": "server.js",
  "bin": {
    "greend-server": "./bin/greend-server.mjs"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "bin/",
    "dist/",
    "logo/",
    "server.js",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "node server.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.2",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "license": "ISC"
}
